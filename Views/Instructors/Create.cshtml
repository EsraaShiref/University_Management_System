@model University_Management_System.Models.Instructor
@{
    ViewData["Title"] = "Add Instructor";
}

<div class="page-header">
    <div class="page-header__meta">
        <span class="text-eyebrow">Faculty</span>
        <h1 class="page-title">Add Instructor</h1>
        <p class="page-subtitle">Register a new faculty member.</p>
    </div>
    <div class="page-header__actions">
        <a asp-action="Index" class="btn btn-secondary">← Back</a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card animate-fade-in-up">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label" asp-for="Name">Full Name <span class="required">*</span></label>
                            <input class="form-control" asp-for="Name" placeholder="e.g. Dr. Sarah Mitchell" />
                            <span class="invalid-feedback" asp-validation-for="Name"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label" asp-for="Age">Age <span class="required">*</span></label>
                            <input class="form-control" asp-for="Age" type="number" placeholder="e.g. 40" />
                            <span class="invalid-feedback" asp-validation-for="Age"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="DepartmentId">Department <span class="required">*</span></label>
                    <select class="form-select" asp-for="DepartmentId" asp-items="ViewBag.Departments">
                        <option value="">— Select Department —</option>
                    </select>
                    <span class="invalid-feedback" asp-validation-for="DepartmentId"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Degree">Degree <span class="required">*</span></label>
                    <input class="form-control" asp-for="Degree" placeholder="e.g. PhD Computer Science" />
                    <span class="invalid-feedback" asp-validation-for="Degree"></span>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" asp-for="Email">Email <span class="required">*</span></label>
                            <input class="form-control" asp-for="Email" type="email" placeholder="e.g. name@uni.edu" />
                            <span class="invalid-feedback" asp-validation-for="Email"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" asp-for="Salary">Salary <span class="required">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input class="form-control" asp-for="Salary" type="number" placeholder="e.g. 85000" />
                            </div>
                            <span class="invalid-feedback" asp-validation-for="Salary"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Address">Address</label>
                    <input class="form-control" asp-for="Address" placeholder="e.g. 12 Oak Street" />
                </div>

                <div style="display:flex;gap:var(--space-3);margin-top:var(--space-6);">
                    <button type="submit" class="btn btn-primary">Add Instructor</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}