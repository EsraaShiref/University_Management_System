@model University_Management_System.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div class="page-header__meta">
        <span class="text-eyebrow">Overview</span>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back — here's what's happening at the university.</p>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card animate-fade-in-up delay-1">
            <div class="stat-card__header">
                <span class="stat-card__label">Students</span>
                <div class="stat-card__icon stat-card__icon--primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                  </svg>
                </div>
            </div>
            <div class="stat-card__value">@Model.TotalStudents</div>
            <div class="stat-card__trend stat-card__trend--up">
                ↑ Active this semester
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card animate-fade-in-up delay-2">
            <div class="stat-card__header">
                <span class="stat-card__label">Courses</span>
                <div class="stat-card__icon stat-card__icon--accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                  </svg>
                </div>
            </div>
            <div class="stat-card__value">@Model.TotalCourses</div>
            <div class="stat-card__trend stat-card__trend--up">
                ↑ Available this semester
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card animate-fade-in-up delay-3">
            <div class="stat-card__header">
                <span class="stat-card__label">Instructors</span>
                <div class="stat-card__icon stat-card__icon--success">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                  </svg>
                </div>
            </div>
            <div class="stat-card__value">@Model.TotalInstructors</div>
            <div class="stat-card__trend stat-card__trend--up">
                ↑ Faculty members
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card animate-fade-in-up delay-4">
            <div class="stat-card__header">
                <span class="stat-card__label">Departments</span>
                <div class="stat-card__icon stat-card__icon--warning">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
                  </svg>
                </div>
            </div>
            <div class="stat-card__value">@Model.TotalDepartments</div>
            <div class="stat-card__trend stat-card__trend--up">
                ↑ Active departments
            </div>
        </div>
    </div>
</div>

<!-- Recent tables side by side -->
<div class="row g-4">
    <div class="col-lg-6">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <span class="table-toolbar__title">Recent Students</span>
                <a asp-controller="Students" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Department</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.RecentStudents)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:var(--space-3);">
                                    <div class="avatar avatar-sm avatar--primary">@(new Func<string, char>(name => { var parts = name.Split(' '); foreach (var p in parts) { var c = p.TrimEnd('.'); if (c != "Dr" && c != "Prof" && c != "Mr" && c != "Ms" && c.Length > 0) return char.ToUpper(c[0]); } return name[0]; })(s.Name))</div>
                                    @s.Name
                                </div>
                            </td>
                            <td><span class="badge badge-primary">@s.Department.Name</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <span class="table-toolbar__title">Recent Courses</span>
                <a asp-controller="Courses" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Enrolled</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.RecentCourses)
                    {
                        <tr>
                            <td>@c.Name</td>
                            <td>
                                <span class="badge badge-success">@c.Enrollments.Count students</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>