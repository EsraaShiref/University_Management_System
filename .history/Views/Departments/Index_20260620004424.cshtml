@model IEnumerable<University_Management_System.Models.Department>
@{ ViewData["Title"] = "Departments"; }

@if (TempData["Success"] != null)
{
  <div class="alert alert-success animate-fade-in-up" style="margin-bottom:var(--space-4);">
    <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
    </svg>
    <div class="alert-content">@TempData["Success"]</div>
  </div>
}

<div class="page-header">
  <div class="page-header__meta">
    <span class="text-eyebrow">Administration</span>
    <h1 class="page-title">Departments</h1>
    <p class="page-subtitle">@Model.Count() academic departments in the university.</p>
  </div>
  <div class="page-header__actions">
    <a asp-action="Create" class="btn btn-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      Add Department
    </a>
  </div>
</div>

<div class="row g-4 animate-fade-in-up">
  @foreach (var d in Model)
  {
    <div class="col-md-6 col-xl-4">
      <div class="card card--primary-top">
        <div class="card-header">
          <h5 class="card-title">@d.Name</h5>
          <div style="display:flex;gap:var(--space-2);">
            <a asp-action="Edit" asp-route-id="@d.DeptId" class="btn btn-ghost btn-icon btn-sm" title="Edit">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125"/>
              </svg>
            </a>
            <button class="btn btn-ghost btn-icon btn-sm" style="color:var(--danger);" title="Delete"
                    onclick="confirmDelete('/Departments/Delete/@d.DeptId')">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
              </svg>
            </button>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:var(--space-3);margin-top:var(--space-2);">
          <div style="font-size:var(--text-sm);color:var(--text-secondary);display:flex;align-items:center;gap:var(--space-2);">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="var(--danger)">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            @d.Location
          </div>
          <div style="font-size:var(--text-sm);color:var(--text-secondary);display:flex;align-items:center;gap:var(--space-2);">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="var(--success)">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
            @d.PhoneNumber
          </div>
        </div>

        <div style="display:flex;gap:var(--space-3);margin-top:var(--space-5);">
          <div style="flex:1;background:var(--surface-overlay);border-radius:var(--radius-lg);padding:var(--space-4);text-align:center;">
            <div style="font-family:var(--font-display);font-size:var(--text-2xl);font-weight:var(--weight-bold);color:var(--primary);">@d.Students.Count</div>
            <div class="text-label" style="margin-top:var(--space-1);">Students</div>
          </div>
          <div style="flex:1;background:var(--surface-overlay);border-radius:var(--radius-lg);padding:var(--space-4);text-align:center;">
            <div style="font-family:var(--font-display);font-size:var(--text-2xl);font-weight:var(--weight-bold);color:var(--accent);">@d.Instructors.Count</div>
            <div class="text-label" style="margin-top:var(--space-1);">Faculty</div>
          </div>
        </div>
      </div>
    </div>
  }
</div>

@await Html.PartialAsync("_DeleteModal")

@section Scripts {
<script>
function confirmDelete(url) {
  document.getElementById('deleteForm').action = url;
  new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
}